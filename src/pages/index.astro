---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="Nick Morrow :|: Portfolio">
  <div class="bg-dark container">
    <div class="content-grid">
      <!-- Introduction (About Me) -->
      <section class="intro grid-container" id="home">
        <h1 class="section__title section__title--intro">
          Hello, I am <strong>Nick Morrow</strong>
        </h1>
        <p class="section__subtitle section__subtitle--intro">Full-Stack Software Engineer</p>
        <div class="introduction-body">
          <p>
            I am a results-driven Technical Leader and Software Engineer dedicated to architecting high-performing
            systems and delivering exceptional customer value. By merging deep technical expertise with a team-first
            mindset, I bridge the gap between complex business objectives and scalable engineering solutions.
          </p>
          <p>
            As a hands-on Full-Stack Developer, I specialize in high-impact modernization efforts, transforming legacy
            architectures into modern, responsive applications using TypeScript, Next.js, and React.js. My approach to
            development is rooted in a diverse technical foundation spanning Spring Boot, .NET, and Next.js, ensuring I
            can lead transitions across various tech stacks with precision.
          </p>
          <p>
            Beyond the code, I am committed to mentoring and training the next generation of developers. I excel at
            translating stakeholder needs into clear technical requirements, managing agile processes to ensure that
            every sprint delivers quality and innovation. I thrive on new challenges and am eager to apply my expertise
            in full-stack modernization and technical mentorship to make an immediate impact on your team.
          </p>
          <p>
            Please contact me if you have any questions or comments. Thank you for your time and I look forward to
            hearing from you.
          </p>
          <p>Sincerely,<br />Nicholas Morrow</p>
        </div>
      </section>

      <!-- Side Content (Contact) -->
      <section class="side-content grid-container">
        <div class="prof-pic">
          <img src="/assets/images/prof_pic.png" alt="a picture of Nick Morrow smiling and looking professional" />
        </div>
        <div class="social-media-group">
          <a href="mailto:nickgmorrow@gmail.com"><i class="fas fa-envelope"></i></a>
          <a href="https://github.com/ngmorrow1029" target="_blank">
            <i class="fab fa-github"></i>
          </a>
          <a href="https://bitbucket.org/ngmorrow1029" target="_blank">
            <i class="fab fa-bitbucket"></i>
          </a>
          <a href="https://www.linkedin.com/in/nicholas-g-morrow" target="_blank">
            <i class="fab fa-linkedin"></i>
          </a>
          <a href="https://vimeo.com/ngmorrow" target="_blank">
            <i class="fab fa-vimeo"></i>
          </a>
          <a href="https://g.dev/nickgmorrow" target="_blank">
            <i class="fab fa-google"></i>
          </a>
        </div>
        <div class="resume-info-group">
          <a href="/assets/docs/NickMorrow_Resume_2026.pdf" target="_blank">View Resume</a>
          |
          <a href="/assets/docs/NickMorrow_Resume_2026.pdf" download>Download Resume</a>
        </div>
        <div class="resume-img">
          <a href="/assets/docs/NickMorrow_Resume_2026.pdf" target="_blank">
            <img id="resumeImg" src="/assets/images/resume/NickMorrow_Resume_2026.png" alt="Resume" /></a
          >
        </div>
      </section>

      <!-- Resume Experience -->
